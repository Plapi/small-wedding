{
  "name": "small-wedding",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "npm --prefix frontend run build",
    "deploy": "npm run build && wrangler deploy",
    "d1:create": "wrangler d1 create small-wedding-db",
    "d1:migrate:local": "wrangler d1 migrations apply small-wedding-db --local",
    "d1:migrate:remote": "wrangler d1 migrations apply small-wedding-db --remote",
    "d1:export": "node scripts/export-d1-data.js"
  },
  "devDependencies": {
    "wrangler": "^4.52.0"
  }
}
